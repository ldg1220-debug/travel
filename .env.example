# Google Maps JavaScript API key (client-exposed). Without this, screens
# using src/components/map/MapProvider.tsx (provider="google") show a
# clean "not configured" state instead of a live map. Must have the
# Places API (New) enabled too — /planner's search box
# (src/app/(app)/planner/PlacesSearchInput.tsx) uses the same key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Kakao Maps JS SDK key (client-exposed, a "JavaScript key" from the Kakao
# Developers console, not the REST key below). Same graceful-degradation
# behavior as the Google key, via src/components/map/MapProvider.tsx
# (provider="kakao").
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Kakao Local REST API key (server-only) used by
# src/app/api/places/search/route.ts for domestic keyword search. A
# different key type than NEXT_PUBLIC_KAKAO_MAP_KEY above — the Kakao
# Developers console issues separate JavaScript and REST keys per app.
KAKAO_REST_API_KEY=

# Google Places API (New) key used by the data pipeline (src/server/pipeline)
# and by src/app/api/places/search/route.ts for international keyword
# search. Without this, both resolve against offline fixtures instead.
GOOGLE_PLACES_API_KEY=

# Optional: LLM key used by the pipeline's authenticity check
# (src/server/pipeline/llmVerifier.ts). Without this a conservative
# heuristic is used instead.
LLM_API_KEY=

# --- Auth & DB (Phase 1.5) ---

# Postgres connection string, e.g. postgresql://user:pass@host:5432/travel
# Run `npm run db:migrate` after setting this to create the schema
# (src/server/db/schema.sql).
DATABASE_URL=

# Required in production. Generate with: npx auth secret
AUTH_SECRET=

# Social login providers (Auth.js v5 env-var inference — a provider is
# only registered once its *_ID is set, see src/auth.ts). Callback URL for
# each is /api/auth/callback/<provider>.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=
